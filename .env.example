SWING_RADAR_AUTO_PROMOTION_MIN_AVG_VOLUME_RATIO=1.05
SWING_RADAR_AUTO_PROMOTION_MIN_CURRENT_VOLUME_RATIO=1.2
SWING_RADAR_AUTO_PROMOTION_ALLOWED_TONES=긍정,중립
SWING_RADAR_AUTO_PROMOTION_MAX_PER_RUN=1
SWING_RADAR_AUTO_PROMOTION_REPORT_PATH=./data/ops/latest-auto-promotion.json
SWING_RADAR_DAILY_CYCLE_REPORT_PATH=./data/ops/latest-daily-cycle.json
SWING_RADAR_AUTO_HEAL_SYNC_SYMBOLS=true
SWING_RADAR_AUTO_HEAL_REPORT_PATH=./data/ops/latest-auto-heal.json
SWING_RADAR_THRESHOLD_ADVICE_PATH=./data/ops/latest-threshold-advice.json
SWING_RADAR_AUTO_HEAL_TASK_NAME=SwingRadarAutoHeal
SWING_RADAR_DAILY_TASK_NAME=SwingRadarDailyKrxCycle
SWING_RADAR_DAILY_TASK_START_TIME=04:00
SWING_RADAR_AUTO_HEAL_START_TIME=05:30
SWING_RADAR_MAINTENANCE_ETA_MINUTES=90
