# Public app URL used by server-side fetch when no dedicated API origin is provided.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Preferred server-side API origin for production deployments.
SWING_RADAR_API_ORIGIN=https://api.swing-radar.com

# Data provider selection: mock | file | postgres
# Local development should normally use `file` so every page reads the same ./data/live snapshots.
SWING_RADAR_DATA_PROVIDER=file

# Optional fallback provider when the primary provider is unavailable.
# Keep this aligned with `file` in local setups to avoid mixing mock/sample data with live snapshots.
SWING_RADAR_FALLBACK_PROVIDER=file

# When SWING_RADAR_DATA_PROVIDER=file, data is loaded from this directory.
SWING_RADAR_DATA_DIR=./data/live

# PostgreSQL provider settings
SWING_RADAR_DATABASE_URL=postgres://postgres:postgres@localhost:15432/swing_radar
SWING_RADAR_DATABASE_SSL=false
SWING_RADAR_DB_POOL_MAX=10
SWING_RADAR_POSTGRES_DB=swing_radar
SWING_RADAR_POSTGRES_USER=postgres
SWING_RADAR_POSTGRES_PASSWORD=postgres
SWING_RADAR_POSTGRES_PORT=15432
SWING_RADAR_APP_PORT=3000

# Admin ingest security
SWING_RADAR_ADMIN_TOKEN=replace-with-long-random-secret
SWING_RADAR_ADMIN_URL=http://localhost:3000/api/admin/ingest

# Freshness thresholds for health checks
SWING_RADAR_STALE_WARNING_MINUTES=1560
SWING_RADAR_STALE_CRITICAL_MINUTES=3000

# External market/news fetch providers
SWING_RADAR_MARKET_PROVIDER=yahoo
SWING_RADAR_MARKET_LOOKBACK_RANGE=6mo
SWING_RADAR_FOCUSED_WATCHLIST_ENABLED=true
SWING_RADAR_FOCUSED_WATCHLIST_TOP_UNIVERSE=80
SWING_RADAR_FOCUSED_WATCHLIST_RECENT_CANDIDATES=40
SWING_RADAR_FOCUSED_WATCHLIST_RECENT_RUNS=5
SWING_RADAR_FOCUSED_WATCHLIST_RECENT_HISTORY_PER_RUN=20
SWING_RADAR_NEWS_PROVIDER=google-news-rss
SWING_RADAR_NAVER_CLIENT_ID=replace-with-naver-client-id
SWING_RADAR_NAVER_CLIENT_SECRET=replace-with-naver-client-secret
SWING_RADAR_NEWS_API_KEY=replace-with-gnews-api-key
SWING_RADAR_NEWS_MAX_ITEMS=5
SWING_RADAR_NEWS_CONCURRENCY=4
SWING_RADAR_NEWS_LIVE_FETCH_TICKER_LIMIT=200
SWING_RADAR_NEWS_PRIORITY_WINDOW=100
SWING_RADAR_NEWS_SOURCE_DIVERSITY_LIMIT=2
SWING_RADAR_NEWS_CURATED_RSS_ENABLED=true
SWING_RADAR_NEWS_RSS_ENABLED=true
SWING_RADAR_NEWS_NAVER_ENABLED=false
SWING_RADAR_NEWS_NAVER_MAX_PRIORITY_RANK=20
SWING_RADAR_NEWS_GNEWS_ENABLED=false
SWING_RADAR_DISCLOSURE_PROVIDER=dart
SWING_RADAR_DART_API_KEY=replace-with-open-dart-api-key
SWING_RADAR_DISCLOSURE_LOOKBACK_DAYS=21
SWING_RADAR_DISCLOSURE_MAX_ITEMS=5
SWING_RADAR_RAW_DATA_DIR=./data/raw

# Symbol sync automation
SWING_RADAR_SYMBOL_SYNC_ENABLED=false
SWING_RADAR_SYMBOL_SYNC_KRX=false
SWING_RADAR_SYMBOL_SYNC_INPUT=./data/config/krx-symbol-master.csv
SWING_RADAR_SYMBOL_SYNC_URL=
SWING_RADAR_SYMBOL_SYNC_STATUS=pending
SWING_RADAR_SYMBOL_SYNC_MERGE=false
SWING_RADAR_KRX_SOURCE_URL=
SWING_RADAR_KRX_DOWNLOADS_DIR=C:\Users\eugen\Downloads
SWING_RADAR_KRX_DOWNLOAD_PATTERN=KRX
SWING_RADAR_KRX_FETCH_MODE=api
SWING_RADAR_KRX_API_PROVIDER=official
SWING_RADAR_KRX_API_BASE_URL=https://data-dbg.krx.co.kr/svc/apis
SWING_RADAR_KRX_API_URL=
SWING_RADAR_KRX_API_KEY=
SWING_RADAR_KRX_API_AUTH_HEADER=AUTH_KEY
SWING_RADAR_KRX_API_METHOD=GET
SWING_RADAR_KRX_API_BAS_DD=
SWING_RADAR_KRX_API_MARKETS=KOSPI,KOSDAQ
SWING_RADAR_KRX_API_RESPONSE_TYPE=csv
SWING_RADAR_KRX_API_DATA_PATH=data
SWING_RADAR_KRX_API_FIELD_TICKER=ticker
SWING_RADAR_KRX_API_FIELD_COMPANY=company
SWING_RADAR_KRX_API_FIELD_MARKET=market
SWING_RADAR_KRX_API_FIELD_SECTOR=sector
SWING_RADAR_KRX_API_FIELD_DART=dartCorpCode

# Daily universe scheduler defaults
SWING_RADAR_UNIVERSE_MARKETS=KOSPI,KOSDAQ
SWING_RADAR_UNIVERSE_LIMIT=0
SWING_RADAR_UNIVERSE_BATCH_SIZE=100
SWING_RADAR_UNIVERSE_CONCURRENCY=4
SWING_RADAR_UNIVERSE_TOP_CANDIDATES=100
SWING_RADAR_RANKING_MIN_PRICE=2000
SWING_RADAR_RANKING_MIN_AVG_TURNOVER20=1500000000
SWING_RADAR_AUTO_PROMOTION_ENABLED=false
SWING_RADAR_AUTO_PROMOTION_LOOKBACK_RUNS=30
SWING_RADAR_AUTO_PROMOTION_MIN_HISTORY_RUNS=20
SWING_RADAR_AUTO_PROMOTION_MIN_APPEARANCES=5
SWING_RADAR_AUTO_PROMOTION_MIN_CONSECUTIVE_APPEARANCES=2
SWING_RADAR_AUTO_PROMOTION_MAX_AVERAGE_RANK=18
SWING_RADAR_AUTO_PROMOTION_MIN_BEST_RANK=10
SWING_RADAR_AUTO_PROMOTION_MIN_AVERAGE_CANDIDATE_SCORE=28
SWING_RADAR_AUTO_PROMOTION_MIN_CURRENT_CANDIDATE_SCORE=30
SWING_RADAR_AUTO_PROMOTION_MIN_AVG_TURNOVER20=30000000000
